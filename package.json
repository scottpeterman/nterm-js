{
  "name": "nterm-electron",
  "version": "0.1.0",
  "description": "A network-aware SSH terminal that understands what it sees",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "author": "Scott Peterman",
  "license": "GPL-3.0",
  "dependencies": {
    "ssh2": "^1.16.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "js-yaml": "^4.1.0",
    "electron-log": "^5.0.0"
},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0",
    "@types/ssh2": "^1.15.0",
    "@types/js-yaml": "^4.0.9"
  },
  "build": {
    "appId": "com.scottpeterman.nterm",
    "productName": "nterm",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*",
      "node_modules/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png"
    }
  }
}
